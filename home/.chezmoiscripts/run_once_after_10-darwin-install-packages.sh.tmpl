{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -eo pipefail

# 管理者権限を必要とするインストールと設定のため、sudo の認証を維持
echo "アプリケーションのインストールのため、管理者パスワードを入力してください。" >&2
sudo -v || exit 1
while true; do
  sudo -n -v
  sleep 60
done 2>/dev/null &
SUDO_KEEPALIVE_PID=$!
trap 'kill "$SUDO_KEEPALIVE_PID" 2>/dev/null || true' EXIT

# Homebrew
# サードパーティ tap は $HOMEBREW_REQUIRE_TAP_TRUST 環境下で信頼が必要
{{ range .packages.darwin.taps -}}
brew trust --tap {{ . | quote }}
{{ end -}}
brew bundle --file=/dev/stdin <<EOF

## taps
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}

## brews
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}

## casks
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}

### mas
{{ range .packages.darwin.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}

EOF

# Xcode
if [ -d "/Applications/Xcode.app" ]; then
  if ! xcodebuild -license check 2>/dev/null; then
    sudo xcodebuild -license accept 2>/dev/null || true
  fi
  xcodebuild -runFirstLaunch 2>/dev/null || true
  if ! xcrun simctl list runtimes 2>/dev/null | grep "iOS" >/dev/null; then
    xcodebuild -downloadPlatform iOS 2>/dev/null || true
  fi
fi

# anyenv
eval "$(anyenv init -)"
if [ ! -d "${XDG_CONFIG_HOME:-${HOME}/.config}/anyenv/anyenv-install" ]; then
  anyenv install --force-init
fi

# nodenv
if [ ! -d "$(anyenv root)/envs/nodenv" ]; then
  anyenv install nodenv
  eval "$(anyenv init -)"
fi

# Node.js
NODE_VERSION=$(cat "{{ .chezmoi.sourceDir }}/../.node-version")
if ! nodenv versions --bare | grep -Fx "$NODE_VERSION" >/dev/null; then
  nodenv install "$NODE_VERSION"
  nodenv global "$NODE_VERSION"
fi

# npm global packages
{{ range .packages.darwin.npms -}}
npm install -g {{ . | quote }}
{{ end -}}

# git-worktree-runner
GWT_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/git-worktree-runner"
if [ ! -d "$GWT_DIR" ]; then
  git clone https://github.com/coderabbitai/git-worktree-runner.git "$GWT_DIR"
  bash "$GWT_DIR/install.sh"
fi

# LazyVim
if [ ! -d "${XDG_CONFIG_HOME:-${HOME}/.config}/nvim" ]; then
  git clone https://github.com/LazyVim/starter "${XDG_CONFIG_HOME:-${HOME}/.config}/nvim"
  rm -rf "${XDG_CONFIG_HOME:-${HOME}/.config}/nvim/.git"
fi

# Hasura CLI
HASURA_CLI_VERSION="v2.49.5"
curl -fL "https://github.com/hasura/graphql-engine/raw/${HASURA_CLI_VERSION}/cli/get.sh" | PATH="$HOME/.local/bin:$PATH" INSTALL_PATH="$HOME/.local/bin" VERSION="$HASURA_CLI_VERSION" bash
{{ end -}}
